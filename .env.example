# ============================================================================
# WOOWCODE — Ortam Değişkenleri (örnek)
# Bu dosyayı ".env.local" olarak kopyalayıp değerleri doldurun.
# Vercel'de ise Project Settings > Environment Variables altına ekleyin.
# ============================================================================

# Sitenin canlı adresi (OG/SEO/metadata için). Örn: https://woowcode.com
NEXT_PUBLIC_SITE_URL=https://woowcode.com

# --- İletişim formu e-postası (Resend) --------------------------------------
# https://resend.com üzerinden alınan API anahtarı
RESEND_API_KEY=

# Form mesajlarının düşeceği gerçek e-posta kutusu
CONTACT_EMAIL=info@woowcode.com

# Gönderici adresi. ⚠️ Resend'de "woowcode.com" domainini doğruladıktan sonra
# aşağıdaki gibi ayarlayın. Doğrulamadan önce boş bırakın (varsayılan sandbox kullanılır).
# CONTACT_FROM=WOOWCODE <info@woowcode.com>
CONTACT_FROM=

# --- Analitik (opsiyonel) ---------------------------------------------------
# Google Analytics 4 ölçüm kimliği. Örn: G-XXXXXXXXXX
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
